# PWA MIME Types - Required for InfinityFree
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType application/json .json
    AddType application/javascript .js
</IfModule>

# Ensure proper MIME type for manifest - use application/manifest+json per spec
<Files "manifest.json">
    <IfModule mod_headers.c>
        Header set Content-Type "application/manifest+json; charset=utf-8"
        Header set X-Content-Type-Options "nosniff"
    </IfModule>
</Files>

# Ensure manifest.php serves with correct headers
<Files "manifest.php">
    <IfModule mod_headers.c>
        Header set Content-Type "application/manifest+json; charset=utf-8"
        Header set X-Content-Type-Options "nosniff"
    </IfModule>
</Files>

# Ensure service worker can control the entire scope
<Files "sw.js">
    <IfModule mod_headers.c>
        Header set Service-Worker-Allowed "/"
        Header set Content-Type "application/javascript"
    </IfModule>
</Files>

# Cache control for PWA assets
<IfModule mod_headers.c>
    <FilesMatch "\.(json|js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

# Prevent directory listing
Options -Indexes

# Allow access to sw.js, manifest files
<FilesMatch "^(sw\.js|manifest\.(json|php))$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>
