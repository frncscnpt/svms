# PWA MIME Types - Required for InfinityFree
AddType application/manifest+json .json
AddType application/javascript .js

# Ensure proper MIME type for manifest
<Files "manifest.json">
    Header set Content-Type "application/manifest+json"
</Files>

# Ensure service worker can control the entire scope
<Files "sw.js">
    Header set Service-Worker-Allowed "/"
    Header set Content-Type "application/javascript"
</Files>

# Cache control for PWA assets
<IfModule mod_headers.c>
    <FilesMatch "\.(json|js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>
